{
	"name": "@cocbot/bot",
	"version": "0.0.1",
	"description": "Call of Cthulhu Game Services",
	"main": "lib/index.js",
	"scripts": {
		"clean": "rimraf lib dist",
		"start": "nodemon",
		"build": "tsc -b .",
		"bundle": "rollup -c rollup.config.js",
		"writeDeployPackageJson": "node writeDeployPackageJson",
		"copyConfiguration": "shx cp -r config/ dist/",
		"predeploy:bot": "run-s writeDeployPackageJson copyConfiguration"
	},
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@rollup/plugin-alias": "^3.1.2",
		"@rollup/plugin-commonjs": "^17.1.0",
		"@rollup/plugin-json": "^4.1.0",
		"@rollup/plugin-node-resolve": "^11.2.0",
		"@tsconfig/node14": "^1.0.0",
		"@types/config": "^0.0.38",
		"@types/express": "^4",
		"@types/nearley": "^2.11.1",
		"@types/node": "^14.14.22",
		"@types/rimraf": "^3.0.0",
		"nodemon": "^2.0.7",
		"npm-run-all": "^4.1.5",
		"rimraf": "^3.0.2",
		"rollup": "^2.39.0",
		"shx": "^0.3.3",
		"ts-node": "^9.1.1",
		"typescript": "^4.1.3"
	},
	"dependencies": {
		"@cocbot/core": "workspace:packages/core",
		"@cocbot/parser": "workspace:packages/parser",
		"@cocbot/schema": "workspace:packages/schema",
		"config": "^3.3.3",
		"cross-fetch": "^3.0.6",
		"discord.js": "^12.5.1",
		"dotenv": "^8.2.0",
		"express": "^4.17.1",
		"graphql": "^15.5.0",
		"graphql-request": "^3.4.0"
	}
}
