{
  "name": "@cocbot/parser",
  "description": "CoCBot Command Parser",
  "version": "0.0.1",
  "main": "src/index.ts",
  "publishConfig": {
    "main": "lib/index.js",
    "types": "lib/index.d.ts"
  },
  "scripts": {
    "build_grammar": "nearleyc grammar/commands.ne > grammar.js",
    "build_ts": "tsc -b tsconfig.json",
    "build": "run-s build_grammar",
    "start": "nodemon"
  },
  "devDependencies": {
    "@types/jest": "^26.0.20",
    "@types/node": "^14.14.22",
    "@types/nearley": "^2.11.1",
    "nearley-unparse": "^1.0.1",
    "nodemon": "^2.0.7",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "nearley": "^2.20.1"
  }
}
